INTERNAL_BEARER_TOKEN=change-me
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_CHAT_LOCATION=global
VERTEX_EMBEDDING_LOCATION=us-central1
VERTEX_CHAT_MODEL=google/gemini-2.5-flash
VERTEX_EMBEDDING_MODEL=gemini-embedding-2-preview
REQUEST_TIMEOUT_SECONDS=60
EMBEDDING_MAX_CONCURRENCY=4
EMBEDDING_MAX_INPUTS_PER_REQUEST=64
EMBEDDING_RETRY_ATTEMPTS=1
EMBEDDING_RETRY_BACKOFF_MS=200
EMBEDDING_ADAPTIVE_CONCURRENCY=false
EMBEDDING_ADAPTIVE_MAX_CONCURRENCY=16
EMBEDDING_ADAPTIVE_WINDOW_SIZE=20
EMBEDDING_ADAPTIVE_WINDOW_SECONDS=60
EMBEDDING_ADAPTIVE_COOLDOWN_SECONDS=30
EMBEDDING_ADAPTIVE_MIN_SAMPLES=5
EMBEDDING_ADAPTIVE_LATENCY_UP_THRESHOLD_MS=4000
EMBEDDING_ADAPTIVE_LATENCY_DOWN_THRESHOLD_MS=8000
EMBEDDING_ADAPTIVE_FAILURE_RATE_UP_THRESHOLD=0.01
EMBEDDING_ADAPTIVE_FAILURE_RATE_DOWN_THRESHOLD=0.10
CHAT_RETRY_ATTEMPTS=1
CHAT_RETRY_BACKOFF_MS=200
# Optional: provide a pre-minted token instead of ADC / Workload Identity.
# VERTEX_ACCESS_TOKEN=
